{{!< default}}

<div class="home-hero">
    <h1 class="home-title">Блог о работе на себя</h1>
    <p class="home-description">Автоматизированный проект «Первой редакции»: как монетизировать свои навыки и&nbsp;не&nbsp;страдать</p>
</div>

<div class="post-grid">
    {{#foreach posts}}
    <article class="post-card">
        <a href="{{url}}" class="post-card-link">
            {{#if feature_image}}
            <div class="post-card-image-link">
                <img class="post-card-image"
                    src="{{img_url feature_image size="m"}}"
                    srcset="{{img_url feature_image size="s"}} 300w,
                            {{img_url feature_image size="m"}} 600w,
                            {{img_url feature_image size="l"}} 1000w"
                    sizes="(max-width: 560px) calc(100vw - 32px), (max-width: 900px) calc(50vw - 36px), 370px"
                    alt="{{title}}"
                    {{#unless @first}}loading="lazy"{{/unless}}
                >
            </div>
            {{/if}}
            <div class="post-card-content">
                <h2 class="post-card-title">{{title}}</h2>
                {{#if custom_excerpt}}
                    <p class="post-card-excerpt">{{custom_excerpt}}</p>
                {{else if excerpt}}
                    <p class="post-card-excerpt">{{excerpt words="20"}}</p>
                {{/if}}
            </div>
        </a>
    </article>
    {{#has number="3"}}
    <aside class="grid-banner">
        <div class="promo-banner-inner">
            <img class="promo-banner-image" src="https://notes.editors.one/content/images/promo/wolf.gif" alt="" loading="lazy" width="200" height="200">
            <div class="promo-banner-content">
                <div class="promo-banner-title">Курс про фриланс</div>
                <p class="promo-banner-text">Как искать клиентов, считать деньги, управлять проектами, договариваться с&nbsp;сложными персонажами&nbsp;— и&nbsp;не&nbsp;сходить с&nbsp;ума.</p>
                <p class="promo-banner-promo">&minus;20% по промокоду <span class="promo-banner-code">БЛОГ</span></p>
                <a class="promo-banner-btn" href="https://editors.one/unemployed?utm_source=seo_blog&utm_medium=internal&utm_campaign=homepage-grid">Звучит интересно</a>
            </div>
        </div>
    </aside>
    {{/has}}
    {{/foreach}}
</div>

{{#if pagination.pages}}
<nav class="pagination">
    {{#if pagination.prev}}
        <a href="{{pagination.prev}}" class="pagination-prev">&larr; Новее</a>
    {{/if}}
    {{#if pagination.next}}
        <a href="{{pagination.next}}" class="pagination-next">Старее &rarr;</a>
    {{/if}}
</nav>
{{/if}}
