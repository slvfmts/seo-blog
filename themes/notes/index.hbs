{{!< default}}

<div class="home-hero">
    <h1 class="home-title">Блог о работе на себя</h1>
    <p class="home-description">Автоматизированный проект «Первой редакции»: как монетизировать свои навыки и&nbsp;не&nbsp;страдать</p>
</div>

<div class="post-grid">
    {{#foreach posts}}
    <article class="post-card">
        <a href="{{url}}" class="post-card-link">
            {{#if feature_image}}
            <div class="post-card-image-link">
                <img class="post-card-image"
                    src="{{img_url feature_image size="m"}}"
                    srcset="{{img_url feature_image size="s"}} 300w,
                            {{img_url feature_image size="m"}} 600w,
                            {{img_url feature_image size="l"}} 1000w"
                    sizes="(max-width: 560px) calc(100vw - 32px), (max-width: 900px) calc(50vw - 36px), 370px"
                    alt="{{title}}"
                    {{#unless @first}}loading="lazy"{{/unless}}
                >
            </div>
            {{/if}}
            <div class="post-card-content">
                <h2 class="post-card-title">{{title}}</h2>
                {{#if custom_excerpt}}
                    <p class="post-card-excerpt">{{custom_excerpt}}</p>
                {{else if excerpt}}
                    <p class="post-card-excerpt">{{excerpt words="20"}}</p>
                {{/if}}
            </div>
        </a>
    </article>
    {{#has number="3"}}
    <aside class="grid-banner" id="gridBanner">
        <img class="grid-banner-image" src="https://notes.editors.one/content/images/promo/wolf-cocktail.webp" alt="" loading="lazy">
        <div class="grid-banner-content">
            <div class="grid-banner-title">5 наших заблуждений о&nbsp;фрилансе</div>
            <p class="grid-banner-text">Поделимся сложностями, которые недооценили или не&nbsp;могли предсказать. Одна история в&nbsp;день, пять дней подряд. А&nbsp;ещё промокод на&nbsp;скидку&nbsp;20%</p>
            <form class="grid-banner-form" id="subscribeForm">
                <div class="grid-banner-form-row">
                    <input type="email" name="email" placeholder="hello@editors.one" required class="grid-banner-input">
                    <button type="submit" class="grid-banner-btn">Получить</button>
                </div>
                <label class="grid-banner-consent">
                    <input type="checkbox" name="consent" required>
                    <span>Соглашаюсь с&nbsp;обработкой данных на&nbsp;условиях <a href="/privacy/" target="_blank">политики</a></span>
                </label>
            </form>
            <div class="grid-banner-success" id="subscribeSuccess" style="display:none">
                <p>Готово! Проверьте почту</p>
            </div>
        </div>
    </aside>
    {{/has}}
    {{/foreach}}
</div>

{{#if pagination.next}}
<div class="load-more-wrap">
    <button class="load-more-btn" data-next="{{page_url pagination.next}}">Ещё статьи</button>
</div>
{{/if}}

<script>
(function() {
    var btn = document.querySelector('.load-more-btn');
    if (!btn) return;
    var grid = document.querySelector('.post-grid');

    btn.addEventListener('click', function() {
        var url = btn.getAttribute('data-next');
        if (!url) return;

        btn.textContent = 'Загрузка…';
        btn.disabled = true;

        fetch(url)
            .then(function(r) { return r.text(); })
            .then(function(html) {
                var doc = new DOMParser().parseFromString(html, 'text/html');
                var cards = doc.querySelectorAll('.post-grid .post-card');
                cards.forEach(function(card) { grid.appendChild(card); });

                var nextBtn = doc.querySelector('.load-more-btn');
                if (nextBtn) {
                    btn.setAttribute('data-next', nextBtn.getAttribute('data-next'));
                    btn.textContent = 'Ещё статьи';
                    btn.disabled = false;
                } else {
                    btn.parentElement.remove();
                }
            })
            .catch(function() {
                btn.textContent = 'Ошибка, попробуйте снова';
                btn.disabled = false;
            });
    });
})();
</script>
