{{!< default}}

<div class="post-grid">
    {{#foreach posts}}
    <article class="post-card">
        <a href="{{url}}" class="post-card-link">
            {{#if feature_image}}
            <div class="post-card-image-link">
                <img class="post-card-image" src="{{feature_image}}" alt="{{title}}">
            </div>
            {{/if}}
            <div class="post-card-content">
                <h2 class="post-card-title">{{title}}</h2>
                {{#if custom_excerpt}}
                    <p class="post-card-excerpt">{{custom_excerpt}}</p>
                {{else if excerpt}}
                    <p class="post-card-excerpt">{{excerpt words="20"}}</p>
                {{/if}}
            </div>
        </a>
    </article>
    {{/foreach}}
</div>

{{#if pagination.pages}}
<nav class="pagination">
    {{#if pagination.prev}}
        <a href="{{pagination.prev}}" class="pagination-prev">&larr; Новее</a>
    {{/if}}
    {{#if pagination.next}}
        <a href="{{pagination.next}}" class="pagination-next">Старее &rarr;</a>
    {{/if}}
</nav>
{{/if}}
